#!/bin/bash

# Guard against re-entry: the amend below would trigger this hook again
# without this check, causing an infinite loop.
if [ -n "$GITMIND_RUNNING" ]; then
    exit 0
fi
export GITMIND_RUNNING=1

GITMIND_DIR="$(git rev-parse --show-toplevel)/.gitmind"

if [ ! -d "$GITMIND_DIR" ]; then
    exit 0
fi

VENV="$GITMIND_DIR/venv"
ENGINE="$GITMIND_DIR/core/engine.py"

if [ -f "$VENV/bin/python" ]; then
    "$VENV/bin/python" "$ENGINE"
else
    python3 "$ENGINE"
fi

# Amend the commit to include the updated metadata.json.
REPO_ROOT="$(git rev-parse --show-toplevel)"
if [ -f "$REPO_ROOT/metadata.json" ]; then
    git add "$REPO_ROOT/metadata.json"
fi
git add "$REPO_ROOT/docs/decisions/" 2>/dev/null || true
git add "$REPO_ROOT/docs/contracts.md" 2>/dev/null || true
git add "$REPO_ROOT/docs/architecture.md" 2>/dev/null || true
git add "$REPO_ROOT/docs/quality-findings.md" 2>/dev/null || true
git add "$REPO_ROOT/metadata/" 2>/dev/null || true

if ! git diff --cached --quiet; then
    git commit --amend --no-edit --no-verify --quiet
fi
